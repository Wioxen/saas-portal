# Copie para .env e preencha com seus valores reais.
# NUNCA commite .env (já está no .gitignore).

# ──────── DATABASE (MariaDB recomendado em produção) ────────
# DB_DRIVER=json   → arquivo JSON (data/discover_trends.json) — default dev local
# DB_DRIVER=mysql  → MariaDB/MySQL — recomendado em prod (índices, ACID, concurrency)
DB_DRIVER=json
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=clonais_saas
DB_USER=clonais_saas
DB_PASS=trocar_senha_aqui
DB_CHARSET=utf8mb4

# ──────── LLM PROVIDERS ────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini

# qual LLM é o padrão quando o portal gera artigo: claude | openai
DEFAULT_LLM=claude

# ──────── SCRAPING ────────
SERPER_API_KEY=xxxxx

# ──────── WORDPRESS (site principal — outros sites via _site_helper.php) ────────
WP_URL=https://comocomprar.com.br
WP_USER=admin
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
WP_DEFAULT_STATUS=draft

# ──────── AFILIADOS ────────
AMAZON_AFFILIATE_URL=https://amzn.to/4ckOgUc

# ──────── WEB STORIES (plugin wp-web-stories-ai) ────────
# Gera story automaticamente após publicar artigo, mas só para clusters com ROI suficiente.
# ROI 10.0 = finanças · 7.6 = saúde · 6.2 = auto · 5.7 = notícia · 4.8 = viagem
# 3.8 = tech · 3.3 = lifestyle/pets · 2.9 = comida · 2.4 = ciência · 1.7 = entreten. · 1.4 = esporte · 1.2 = geral
# Default 5.0 → gera para notícia, auto, saúde, finanças. Pula esporte/entreten./comida/etc.
WEBSTORY_ENABLED=1
WEBSTORY_ROI_MIN=5.0
WEBSTORY_MIN_SCENES=5
WEBSTORY_MAX_SCENES=9

# ──────── ONESIGNAL (push notifications) ────────
# Credenciais do dashboard.onesignal.com · Settings · Keys & IDs
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=os_v2_app_xxxxx
ONESIGNAL_ENABLED=1
ONESIGNAL_ROI_MIN=5.0
# Só dispara push quando publicar nos sites listados (csv). Se vazio, qualquer site.
ONESIGNAL_SITE_TARGET=cursosenac

# ──────── META (Facebook Page + Instagram Business) ────────
# Long-lived Page Token (expires_at=0) — compartilhado entre páginas que usam mesma persona.
FB_PAGE_TOKEN_MARIA=EAAR_xxxxx
IG_TOKEN_CURSOSENAC=IGAA_xxxxx
IG_TOKEN_GUIADOSCURSOS=IGAA_xxxxx

# ──────── WHATSAPP (opcional — bloco de captura de lead) ────────
WHATSAPP_NUMBER=5571992354308
WHATSAPP_GROUP_URL=https://gruposwhats.app/group/1044539
WHATSAPP_CTA_TEXT=Receba ofertas relâmpago no WhatsApp

# ──────── LOCAL / METADADOS ────────
SITE_NAME=Como Comprar
SITE_URL=http://localhost/apiclaudephp
AUTOR=Equipe Como Comprar

# ──────── CLOUDFLARE CACHE PURGE — opcional ────────
# Quando configurado, Title/P1/Meta swappers purgam URL no edge após troca
# (mudança visível em segundos em vez de esperar TTL 4h+).
# 100% defensivo: sem token aqui ou sem cloudflare_zone_id no sites.php → no-op silencioso.
#
# Como obter o token:
#   1. Cloudflare → My Profile → API Tokens → Create Token
#   2. Use template "Edit zone DNS" como base (mais rápido) ou crie custom
#   3. Permissions: Zone → Cache Purge → Edit
#   4. Zone Resources: Include → Specific zone(s) → escolha as zonas dos seus 6 sites
#
# Como obter zone_id de cada site:
#   Cloudflare → escolher zona → API (right sidebar) → Zone ID (32 chars hex)
CLOUDFLARE_API_TOKEN=

# ──────── KILL SWITCH — pause global de emergência ────────
# PIPELINE_PAUSED=1 → DiscoverGerador, tick_filas, scripts/pingo retornam early sem trabalho.
# Reading/dashboards/smoke continuam. Pausa NÃO precisa restart — cada execução re-lê .env.
# Use quando: gasto fora da curva, WP comprometido, notícia delicada, bug crítico recém-descoberto.
PIPELINE_PAUSED=0
PIPELINE_PAUSED_REASON=

# ──────── HEARTBEAT — alerta de pipeline morto ────────
# Cron horário verifica último post por site. Se > N horas, alerta via HealthWebhook.
# Default 4h (Discover quer freshness). Aumente em sites com publicação esparsa.
HEARTBEAT_MAX_HORAS_SEM_POST=4
HEARTBEAT_RATE_LIMIT_HORAS=4

# ──────── DEAD-LETTER QUEUE — max retries por trend ────────
# Trend que falhou N vezes consecutivas → status 'falhado_max_retries', sai da fila.
# Default 3 (suficiente pra cobrir Claude/Serper transients sem queimar tokens em loop).
DLQ_MAX_FALHAS_CONSECUTIVAS=3

# ──────── COST GUARD — hard cap diário ────────
# Bloqueia geração quando gasto agregado do dia (Claude+Serper+OpenAI) ultrapassa o limite.
# Defesa contra bug em loop / runaway de tokens. Cap por site é "best-effort" via proporção.
# Ajuste depois de 1-2 semanas de operação real (CostTracker mostra média).
COST_GUARD_ENABLED=1
COST_DAILY_LIMIT_USD=20
COST_DAILY_LIMIT_PER_SITE_USD=5
