# ── Secrets / config local ──
.env
.env.local
.env.*.local

# config.php é só wrapper de Env::get() — pode ir pro repo

# ── Backups e artefatos com WP creds em plaintext ──
# sites.php agora é safe pra commit (lê senhas via Env::get do .env).
# .bak/scripts antigos ainda têm senhas hardcoded — gitignored até refactor.
sites.php.bak
scripts/aplicar_fixes_adsense.php
scripts/auditar_pre_adsense.php
scripts/auditar_adsense_completo.php
scripts/instalar_cookie_consent.php
scripts/revisar_posts_anti_ia.php
scripts/reorganizar_categorias_guiadoscursos.php
scripts/_empacotar_deploy.php

# ── Estado runtime / cache / logs (12MB+) ──
# data/ e pages/ são runtime — só a estrutura de pastas vai pro repo (.gitkeep)
# Templates de seed inicial vivem em seeds/ (fora do volume mount do EasyPanel)
data/**
!data/**/
!data/**/.gitkeep
# Config (não-runtime) — devem versionar:
!data/jogos_vitoria.json
!data/hubs_vitoria.php
# Configs llm-wiki — aliases das entity/concept pages (mantido pelo EntityHubBuilder)
# + lotes de hubs (configs JSON pra criação em batch)
!data/entity_pages_cache/
!data/entity_pages_cache/*_aliases.json
!data/hubs_lote/
!data/hubs_lote/*.json
pages/**
!pages/.gitkeep
*.log
*.bak

# ── Sessão Claude Code local ──
.claude/

# ── WordPress espelho (não pertence ao repo) ──
wp-content/

# ── Artefatos de build ──
*.zip
!plugin/*.zip

# ── OS / IDE ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
